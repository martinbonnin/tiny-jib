{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchPackageNames: ["org.jetbrains.kotlin.plugin.serialization:org.jetbrains.kotlin.plugin.serialization.gradle.plugin"],
      matchUpdateTypes: ["major", "minor"],
      enabled: false,
    },
    {
      matchPackageNames: ["dev.gradleplugins:gradle-api"],
      enabled: false,
    },
  ],
}
